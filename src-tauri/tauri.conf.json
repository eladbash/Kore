{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "kore",
  "version": "0.1.0",
  "identifier": "com.example.kore",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Kore",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "visible": true
      }
    ],
    "security": {
      "capabilities": [
        "default"
      ]
    }
  },
  "plugins": {},
  "bundle": {
    "macOS": {
      "minimumSystemVersion": "14.0"
    }
  }
}

